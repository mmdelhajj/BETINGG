# ─── CryptoBet Environment Configuration ─────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Application ─────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://cryptobet:your_password@localhost:5432/cryptobet
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cryptobet
DB_USER=cryptobet

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Authentication ──────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OAuth2 — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# OAuth2 — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback

# ─── Frontend ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_SITE_NAME=CryptoBet
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Crypto Wallets / HD Wallet ────────────────────────
# BIP39 mnemonic for HD wallet derivation.
# WARNING: Use a testnet mnemonic for development. NEVER commit real mnemonics.
# Default is a well-known test mnemonic - DO NOT use with real funds.
WALLET_MNEMONIC=test test test test test test test test test test test junk

# EVM RPCs (Ethereum, BSC, Polygon, Arbitrum)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/demo
EVM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/demo
BSC_RPC_URL=https://bsc-dataseed1.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
EVM_MNEMONIC=

# Bitcoin / UTXO chains
BTC_RPC_URL=https://blockstream.info/api
LTC_RPC_URL=https://litecoinspace.org/api
DOGE_RPC_URL=https://dogechain.info/api/v1
NOWNODES_API_KEY=

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# TRON
TRON_API_URL=https://api.trongrid.io
TRON_API_KEY=

# ─── Fiat On-Ramp ───────────────────────────────────────
MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=
MOONPAY_WEBHOOK_SECRET=

SWAPPED_API_KEY=
SWAPPED_WEBHOOK_SECRET=

# ─── Email ───────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
SMTP_FROM=noreply@cryptobet.com

# ─── File Storage ────────────────────────────────────────
# Local or S3
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# S3 (if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=cryptobet-uploads

# ─── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Admin ───────────────────────────────────────────────
ADMIN_EMAIL=admin@cryptobet.com
ADMIN_PASSWORD=change_me_immediately

# ─── Geo Restriction ────────────────────────────────────
GEOIP_DB_PATH=./data/GeoLite2-Country.mmdb
ENABLE_GEO_RESTRICTION=false

# ─── Withdrawal Settings ────────────────────────────────
AUTO_APPROVE_THRESHOLD=500
LARGE_WITHDRAWAL_THRESHOLD=5000

# ─── VIP Settings ───────────────────────────────────────
WELCOME_PACKAGE_DURATION_DAYS=30
WELCOME_PACKAGE_MAX_VALUE=2500

# ─── Backup ─────────────────────────────────────────────
BACKUP_DIR=/backups/cryptobet
BACKUP_RETENTION_DAYS=30

# ─── Monitoring ──────────────────────────────────────────
# Sentry (optional)
SENTRY_DSN=

# ─── Telegram Bot (optional) ────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# ─── The Odds API ──────────────────────────────────────
# Get your free API key at https://the-odds-api.com/
# Free tier: 500 credits/month
# Leave empty or set to YOUR_API_KEY_HERE to use mock data mode
ODDS_API_KEY=YOUR_API_KEY_HERE
ODDS_API_MARGIN=5
ODDS_API_SYNC_INTERVAL_MINUTES=15
ODDS_API_MONTHLY_BUDGET=500
